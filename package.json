{
  "name": "gmm-haproxy-vscode",
  "displayName": "HAProxy Config",
  "description": "Full language support for HAProxy configuration files — syntax highlighting, autocompletion, validation, hover docs, snippets, and formatting. Multi-version support from 2.4 LTS to 3.1.",
  "version": "0.1.1",
  "publisher": "gmm",
  "author": {
    "name": "Juan Torchia",
    "email": "j.s.torchia@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gmm/gmm-haproxy-vscode"
  },
  "bugs": {
    "url": "https://github.com/gmm/gmm-haproxy-vscode/issues"
  },
  "engines": {
    "vscode": "^1.110.0",
    "node": ">=24.0.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets",
    "Formatters"
  ],
  "keywords": [
    "haproxy",
    "load-balancer",
    "proxy",
    "config",
    "lsp",
    "syntax",
    "devops",
    "sre",
    "infrastructure"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:haproxy"
  ],
  "main": "./client/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "haproxy",
        "aliases": [
          "HAProxy",
          "haproxy"
        ],
        "extensions": [
          ".cfg",
          ".conf"
        ],
        "filenames": [
          "haproxy.cfg",
          "haproxy.conf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "haproxy",
        "scopeName": "source.haproxy",
        "path": "./syntaxes/haproxy.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "haproxy",
        "path": "./snippets/haproxy.json"
      }
    ],
    "configuration": {
      "title": "HAProxy",
      "properties": {
        "haproxy.version": {
          "type": "string",
          "default": "3.1",
          "enum": [
            "2.4",
            "2.6",
            "2.8",
            "3.0",
            "3.1"
          ],
          "enumDescriptions": [
            "HAProxy 2.4 LTS",
            "HAProxy 2.6 LTS",
            "HAProxy 2.8 LTS (recommended LTS)",
            "HAProxy 3.0",
            "HAProxy 3.1 (latest stable)"
          ],
          "description": "HAProxy version to validate configuration against.",
          "markdownDescription": "HAProxy version to validate configuration against. Affects which directives are considered valid, deprecated, or unavailable."
        },
        "haproxy.validate.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable live configuration validation.",
          "markdownDescription": "Enable or disable live validation diagnostics (errors, warnings) in HAProxy config files."
        },
        "haproxy.completion.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable autocompletion.",
          "markdownDescription": "Enable or disable context-aware autocompletion for HAProxy directives and options."
        },
        "haproxy.trace.server": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "description": "Language server trace level for debugging.",
          "markdownDescription": "Controls LSP message tracing. Set to `messages` or `verbose` to debug language server communication."
        }
      }
    },
    "commands": [
      {
        "command": "haproxy.restartServer",
        "title": "HAProxy: Restart Language Server"
      },
      {
        "command": "haproxy.selectVersion",
        "title": "HAProxy: Select Version"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -b",
    "build": "npm run build:client && npm run build:server",
    "build:client": "esbuild client/src/extension.ts --bundle --outfile=client/out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:server": "esbuild server/src/server.ts --bundle --outfile=server/out/server.js --format=cjs --platform=node --sourcemap",
    "watch": "npm run watch:client & npm run watch:server",
    "watch:client": "esbuild client/src/extension.ts --bundle --outfile=client/out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "watch:server": "esbuild server/src/server.ts --bundle --outfile=server/out/server.js --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --testPathPattern=\"test/(parser|validator|completion|hover|grammar|formatter|symbols|definition|codeactions|folding)\"",
    "test:integration": "node ./test/integration/runTests.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "29.5.14",
    "@types/mocha": "10.0.10",
    "@types/node": "^22.17.2",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.7.1",
    "esbuild": "0.28.0",
    "eslint": "10.2.0",
    "eslint-plugin-security": "^4.0.0",
    "glob": "^11.1.0",
    "jest": "29.7.0",
    "mocha": "^11.3.0",
    "ts-jest": "29.2.6",
    "typescript": "6.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5",
    "globals": "^15.15.0"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  }
}

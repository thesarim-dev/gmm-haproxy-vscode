{
  "Global block": {
    "prefix": "global",
    "body": [
      "global",
      "    daemon",
      "    log ${1:/dev/log} local0",
      "    log ${2:/dev/log} local1 notice",
      "    maxconn ${3:50000}",
      "    nbthread ${4:4}",
      "    stats socket ${5:/run/haproxy/admin.sock} mode 660 level admin expose-fd listeners",
      "    stats timeout ${6:30s}",
      "$0"
    ],
    "description": "HAProxy global section with common settings"
  },
  "Defaults block": {
    "prefix": "defaults",
    "body": [
      "defaults",
      "    mode ${1|http,tcp|}",
      "    log global",
      "    option httplog",
      "    option dontlognull",
      "    option http-server-close",
      "    option forwardfor except 127.0.0.0/8",
      "    option redispatch",
      "    retries ${2:3}",
      "    timeout http-request ${3:10s}",
      "    timeout queue ${4:1m}",
      "    timeout connect ${5:10s}",
      "    timeout client ${6:1m}",
      "    timeout server ${7:1m}",
      "    timeout http-keep-alive ${8:10s}",
      "    timeout check ${9:10s}",
      "    maxconn ${10:3000}",
      "$0"
    ],
    "description": "HAProxy defaults section with sensible values"
  },
  "Frontend HTTP": {
    "prefix": "frontend",
    "body": [
      "frontend ${1:http-in}",
      "    bind *:${2:80}",
      "    mode http",
      "    option httplog",
      "    default_backend ${3:backend-name}",
      "$0"
    ],
    "description": "HTTP frontend"
  },
  "Frontend HTTPS": {
    "prefix": "frontend-ssl",
    "body": [
      "frontend ${1:https-in}",
      "    bind *:${2:443} ssl crt ${3:/etc/ssl/certs/haproxy.pem}",
      "    mode http",
      "    option httplog",
      "    http-request redirect scheme https unless { ssl_fc }",
      "    default_backend ${4:backend-name}",
      "$0"
    ],
    "description": "HTTPS frontend with SSL termination"
  },
  "Backend HTTP": {
    "prefix": "backend",
    "body": [
      "backend ${1:backend-name}",
      "    mode http",
      "    balance ${2|roundrobin,leastconn,source,random|}",
      "    option httpchk ${3:GET} ${4:/health}",
      "    http-check expect status 200",
      "    server ${5:web1} ${6:10.0.0.1}:${7:8080} check inter ${8:2s} rise ${9:2} fall ${10:3}",
      "$0"
    ],
    "description": "HTTP backend with health check"
  },
  "Backend HTTPS": {
    "prefix": "backend-ssl",
    "body": [
      "backend ${1:backend-ssl}",
      "    mode http",
      "    balance ${2|roundrobin,leastconn,source|}",
      "    option ssl-hello-chk",
      "    server ${3:web1} ${4:10.0.0.1}:${5:443} ssl verify none check inter ${6:2s}",
      "$0"
    ],
    "description": "HTTPS backend with SSL pass-through"
  },
  "Listen block": {
    "prefix": "listen",
    "body": [
      "listen ${1:stats}",
      "    bind *:${2:8404}",
      "    mode http",
      "    stats enable",
      "    stats uri ${3:/stats}",
      "    stats refresh ${4:10s}",
      "    stats auth ${5:admin}:${6:password}",
      "$0"
    ],
    "description": "HAProxy listen block (combined frontend+backend)"
  },
  "ACL definition": {
    "prefix": "acl",
    "body": "acl ${1:acl_name} ${2:hdr(host) -i} ${3:example.com}",
    "description": "Access Control List definition"
  },
  "use_backend with condition": {
    "prefix": "use_backend",
    "body": "use_backend ${1:backend-name} if ${2:acl_name}",
    "description": "Route to backend if ACL matches"
  },
  "server line": {
    "prefix": "server",
    "body": "server ${1:web1} ${2:10.0.0.1}:${3:8080} check inter ${4:2s} rise ${5:2} fall ${6:3} weight ${7:1}",
    "description": "Backend server with health check parameters"
  },
  "option httpchk": {
    "prefix": "httpchk",
    "body": "option httpchk ${1|GET,HEAD,POST|} ${2:/health} HTTP/${3|1.0,1.1|}",
    "description": "HTTP health check option"
  }
}
